{
  "name": "vibetest.client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode guest",
    "dev:full": "vite --mode full",
    "build": "tsc -b && vite build --mode full",
    "build:guest": "tsc -b && vite build --mode guest",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:guest": "vite preview --mode guest",
    "build:e2e-guest": "tsc -b && vite build --mode e2e-guest",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "e2e": "playwright test --config=playwright.guest.config.ts && playwright test --config=playwright.full.config.ts",
    "e2e:guest": "playwright test --config=playwright.guest.config.ts",
    "e2e:full": "playwright test --config=playwright.full.config.ts",
    "e2e:install": "playwright install chromium",
    "generate:seed": "node scripts/generate-seed-data.mjs"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "@playwright/test": "^1.55.0"
  }
}